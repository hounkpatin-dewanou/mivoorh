# Copier vers .env sur le serveur de production (XAMPP / hébergement)
# Ne jamais commiter le fichier .env réel avec des mots de passe.

APP_NAME=MivooRH
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://api.votre-domaine.bj

APP_LOCALE=fr
APP_FALLBACK_LOCALE=fr

LOG_CHANNEL=stack
LOG_LEVEL=warning

# MySQL — créer la base dans phpMyAdmin avant migrate
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=mivoorh
DB_USERNAME=mivoorh_user
DB_PASSWORD=changez_moi

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=true

CACHE_STORE=database
QUEUE_CONNECTION=database

# URL du frontend Vue (build dist) pour CORS / Sanctum
FRONTEND_URL=https://rh.votre-domaine.bj
SANCTUM_STATEFUL_DOMAINS=rh.votre-domaine.bj,localhost

MAIL_MAILER=smtp
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS="noreply@mivoorh.bj"
MAIL_FROM_NAME="${APP_NAME}"
