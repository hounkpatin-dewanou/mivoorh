# Modèle pour Docker — les valeurs sont injectées par docker-compose + entrypoint-api.sh
# Ne pas committer de .env réel.

APP_NAME=MivooRH
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8002

DB_CONNECTION=mysql
DB_HOST=db
DB_PORT=3306
DB_DATABASE=mivoorh
DB_USERNAME=mivoorh
DB_PASSWORD=mivoorh

SESSION_DRIVER=database
CACHE_STORE=database
QUEUE_CONNECTION=database

FRONTEND_URL=http://localhost:8002
SANCTUM_STATEFUL_DOMAINS=localhost,localhost:8002,127.0.0.1,127.0.0.1:8002
